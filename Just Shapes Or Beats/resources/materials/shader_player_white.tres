[gd_resource type="ShaderMaterial" format=3 uid="uid://bcujxb5745x2a"]

[sub_resource type="Shader" id="5"]
code = "shader_type canvas_item;

// Colors the whole thing white
// But also makes a circular sector of the sprite

varying vec4 modulate_color;

void vertex() {
    modulate_color = COLOR;
}

void fragment(){
    COLOR = texture(TEXTURE, UV);
    COLOR.rgb = vec3(1.0);

    float sector = modulate_color.g * TAU - PI;
    float angle = atan(UV.y - 0.5, UV.x - 0.5);

    if (angle >= sector) {
        COLOR.a = 0.0;
    }
}"

[resource]
shader = SubResource("5")
