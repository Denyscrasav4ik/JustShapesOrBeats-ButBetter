[sub_resource type="Shader" id="5"]
code = "shader_type canvas_item;

uniform float size;

float distance_to_middle(vec2 uv){
	return length(uv - vec2(0.5));
}

void fragment(){
	if(distance_to_middle(UV) <= size){
		COLOR = vec4(0);
	} else {
		COLOR = vec4(1);
	}
}"

