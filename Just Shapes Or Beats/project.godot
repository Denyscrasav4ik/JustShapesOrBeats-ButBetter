;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Just Shapes Or Beats"
run/main_scene="res://scenes/menu.tscn"
config/features=PackedStringArray("4.7")
boot_splash/show_image=false
config/icon="uid://cn4kcf41vbvuj"

[audio]

buses/default_bus_layout="uid://bv0rc0a2224cv"

[autoload]

TS="*res://scenes/ts.gd"
GameMethods="*res://scenes/game_methods.gd"
GameSettings="*res://scenes/game_settings.gd"
GameVars="*res://scenes/game_vars.gd"
ControlFocusSquare="*res://scenes/control_focus_square.tscn"

[debug]

shapes/icon="uid://do7picnyorn8i"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/fullscreen=true

[dotnet]

project/assembly_name="Just Shapes Or Beats"

[editor_plugins]

enabled=PackedStringArray()

[gui]

common/drop_mouse_on_gui_input_disabled=true

