[sub_resource type="Shader" id="20"]
code = "shader_type canvas_item;

varying vec4 modulate_color;

void vertex() {
    modulate_color = COLOR;
}

void fragment() {
    COLOR = texture(TEXTURE, UV);

    float sector = modulate_color.g * TAU - PI;
    float angle = atan(UV.x - 0.5, UV.y - 0.5);

    if (angle >= sector) {
        COLOR.a = 0.0;
    }
}"

[sub_resource type="ShaderMaterial" id="21"]
shader = SubResource("20")

[sub_resource type="Shader" id="15"]
code = "shader_type canvas_item;

// Player shader
// Creates the purple hit coloring and represents HP
// If modulate.r is higher than 0.5, then it signals hit
// modulate.g indicates sector

uniform vec4 hit_color: source_color;

varying vec4 v_modulate;

void vertex() {
    v_modulate = COLOR;
}

void fragment() {
    vec4 color = texture(TEXTURE, UV);

    float weight = round(v_modulate.r);

    color.rgb = (color.rgb * weight + hit_color.rgb * (1.0 - weight));
    COLOR = color;

    float sector = v_modulate.g * TAU - PI;
    float angle = atan(UV.y - 0.5, UV.x - 0.5);

    if (angle >= sector) {
        COLOR.a = 0.0;
    }
}"

